      "source": [
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd\n",
        "import seaborn as sns # Import seaborn\n",
        "\n",
        "# The SQL query result is directly a pandas DataFrame when autopandas is enabled.\n",
        "# We can assign it directly to df_revenue.\n",
        "sql_query_result = %sql SELECT p.categoryname, SUM(CASE WHEN DATE_PART('year', s.orderdate) = 2022 THEN (s.quantity * s.netprice * s.exchangerate) ELSE 0 END) AS total_revenue_2022, SUM(CASE WHEN DATE_PART('year', s.orderdate) = 2023 THEN (s.quantity * s.netprice * s.exchangerate) ELSE 0 END) AS total_revenue_2023 FROM sales s INNER JOIN product p ON s.productkey = p.productkey WHERE DATE_PART('year', s.orderdate) = 2022 OR DATE_PART('year', s.orderdate) = 2023 GROUP BY p.categoryname ORDER BY p.categoryname\n",
        "\n",
        "df_revenue = sql_query_result # No need for .DataFrame() as it's already a DataFrame\n",
        "\n",
        "# Prepare data for plotting\n",
        "# We'll melt the DataFrame to make it easier for seaborn to plot grouped bars\n",
        "df_melted = df_revenue.melt(id_vars=['categoryname'],\n",
        "                            value_vars=['total_revenue_2022', 'total_revenue_2023'],\n",
        "                            var_name='Year',\n",
        "                            value_name='Total Revenue')\n",
        "\n",
        "# Rename Year values for better display\n",
        "df_melted['Year'] = df_melted['Year'].replace({'total_revenue_2022': '2022', 'total_revenue_2023': '2023'})\n",
        "\n",
        "plt.figure(figsize=(14, 8))\n",
        "sns.barplot(x='categoryname', y='Total Revenue', hue='Year', data=df_melted, palette='viridis')\n",
        "plt.title('Total Revenue by Category (2022 vs 2023)', fontsize=16)\n",
        "plt.xlabel('Category Name', fontsize=12)\n",
        "plt.ylabel('Total Revenue', fontsize=12)\n",
        "plt.xticks(rotation=45, ha='right')\n",
        "plt.legend(title='Year')\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
