        "%%sql\n",
        "\n",
        "SELECT DISTINCT\n",
        "--s.orderdate,\n",
        "p.categoryname,\n",
        "SUM(CASE WHEN DATE_PART('year', s.orderdate) = 2022 THEN (s.quantity * s.netprice * s.exchangerate) ELSE 0 END) AS total_revenue_2022,\n",
        "SUM(CASE WHEN DATE_PART('year', s.orderdate) = 2023 THEN (s.quantity * s.netprice * s.exchangerate) ELSE 0 END) AS total_revenue_2023\n",
        "\n",
        "FROM\n",
        "  sales s\n",
        "INNER JOIN\n",
        "  product p\n",
        "ON s.productkey = p.productkey\n",
        "\n",
        "WHERE\n",
        "  DATE_PART('year', s.orderdate) = 2022\n",
        "  OR\n",
        "  DATE_PART('year', s.orderdate) = 2023\n",
        "GROUP BY\n",
        " -- s.orderdate,\n",
        "  p.categoryname\n",
        "\n",
        "ORDER BY\n",
        "--  s.orderdate\n",
        "p.categoryname\n"
      ]
